{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "m3u8-to-mp4",
  "version": "0.1.0",
  "identifier": "com.m3u8tomp4.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm --prefix ui run dev",
    "beforeBuildCommand": "npm --prefix ui run build"
  },
  "app": {
    "windows": [
      {
        "title": "m3u8 → mp4",
        "width": 900,
        "height": 700,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/m3u8-sidecar"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
